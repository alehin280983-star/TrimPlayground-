# AI Provider Keys (server-side)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=

# Feature Flags
FEATURE_COMPARE=true
FEATURE_LIVE=true
FEATURE_WORKFLOWS=false
